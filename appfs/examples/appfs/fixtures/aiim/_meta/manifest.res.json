{
  "app_id": "aiim",
  "display_name": "AIIM",
  "contract_version": "0.1",
  "conformance": {
    "appfs_version": "0.1",
    "profiles": [
      "core"
    ],
    "recommended": [
      "observer",
      "progress_policy"
    ],
    "extensions": [],
    "implementation": {
      "name": "aiim-adapter",
      "version": "0.1.0",
      "language": "rust"
    }
  },
  "stream": {
    "path": "_stream/events.evt.jsonl",
    "line_schema": "_meta/schemas/events.evt.schema.json",
    "cursor_path": "_stream/cursor.res.json",
    "replay_path_template": "_stream/from-seq/{seq}.evt.jsonl"
  },
  "nodes": {
    "chats/{chat_id}/messages.res.jsonl": {
      "kind": "resource",
      "output_mode": "jsonl",
      "output_schema": "_meta/schemas/chat.message.item.output.schema.json",
      "snapshot": {
        "max_materialized_bytes": 10485760
      }
    },
    "chats/chat-oversize/messages.res.jsonl": {
      "kind": "resource",
      "output_mode": "jsonl",
      "output_schema": "_meta/schemas/chat.message.item.output.schema.json",
      "snapshot": {
        "max_materialized_bytes": 128
      }
    },
    "feed/recommendations.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/chat.messages.page.output.schema.json",
      "paging": {
        "enabled": true,
        "mode": "live",
        "default_page_size": 20,
        "max_page_size": 50,
        "handle_ttl_sec": 900
      }
    },
    "feed/recommendations-expired.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/chat.messages.page.output.schema.json",
      "paging": {
        "enabled": true,
        "mode": "live",
        "default_page_size": 20,
        "max_page_size": 50,
        "handle_ttl_sec": 900
      }
    },
    "feed/recommendations-long.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/chat.messages.page.output.schema.json",
      "paging": {
        "enabled": true,
        "mode": "live",
        "default_page_size": 20,
        "max_page_size": 50,
        "handle_ttl_sec": 900
      }
    },
    "contacts/{contact_id}/profile.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/contact.profile.output.schema.json"
    },
    "_app/control.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/app.control.output.schema.json"
    },
    "_app/actions.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/app.actions.output.schema.json"
    },
    "_app/available_scopes.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/app.available_scopes.output.schema.json"
    },
    "_app/current_scope.res.json": {
      "kind": "resource",
      "output_mode": "json",
      "output_schema": "_meta/schemas/app.current_scope.output.schema.json"
    },
    "contacts/{contact_id}/send_message.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "inline",
      "inline_timeout_ms": 2000,
      "input_schema": "_meta/schemas/send_message.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 8192,
      "rate_limit_hint": "30/minute",
      "event_types": [
        "action.accepted",
        "action.completed",
        "action.failed"
      ],
      "example": "echo '{\"text\":\"hi\"}' >> /app/aiim/contacts/zhangsan/send_message.act"
    },
    "_app/enter_scope.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "inline",
      "inline_timeout_ms": 1000,
      "input_schema": "_meta/schemas/enter_scope.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 2048,
      "event_types": [
        "action.completed",
        "action.failed"
      ],
      "example": "echo '{\"target_scope\":\"chat-long\"}' >> /app/aiim/_app/enter_scope.act"
    },
    "_app/refresh_structure.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "inline",
      "inline_timeout_ms": 1000,
      "input_schema": "_meta/schemas/refresh_structure.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 2048,
      "event_types": [
        "action.completed",
        "action.failed"
      ],
      "example": "echo '{}' >> /app/aiim/_app/refresh_structure.act"
    },
    "files/{file_id}/download.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "streaming",
      "input_schema": "_meta/schemas/download.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 4096,
      "rate_limit_hint": "10/minute",
      "progress_policy": {
        "mode": "app_defined",
        "max_silence_ms": 10000
      },
      "event_types": [
        "action.accepted",
        "action.progress",
        "action.completed",
        "action.failed"
      ],
      "example": "echo '{\"target\":\"C:/tmp/file-001.bin\"}' >> /app/aiim/files/file-001/download.act"
    },
    "_snapshot/refresh.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "inline",
      "inline_timeout_ms": 1000,
      "input_schema": "_meta/schemas/snapshot.refresh.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 2048,
      "event_types": [
        "action.completed",
        "action.failed"
      ]
    },
    "_paging/fetch_next.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "inline",
      "inline_timeout_ms": 500,
      "input_schema": "_meta/schemas/paging.fetch_next.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 512,
      "event_types": [
        "action.completed",
        "action.failed"
      ]
    },
    "_paging/close.act": {
      "kind": "action",
      "input_mode": "json",
      "execution_mode": "inline",
      "inline_timeout_ms": 500,
      "input_schema": "_meta/schemas/paging.close.input.schema.json",
      "event_schema": "_meta/schemas/events.evt.schema.json",
      "max_payload_bytes": 512,
      "event_types": [
        "action.completed",
        "action.failed"
      ]
    }
  }
}
