{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appfs.dev/schemas/send_message.input.schema.json",
  "title": "AIIM Send Message Input",
  "type": "object",
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1
    },
    "client_token": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ]
    }
  },
  "required": [
    "text"
  ],
  "additionalProperties": true
}
