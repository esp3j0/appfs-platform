{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appfs.dev/schemas/app.available_scopes.output.schema.json",
  "title": "AIIM App Available Scopes Output",
  "type": "object",
  "required": [
    "app_id",
    "active_scope",
    "scopes"
  ],
  "properties": {
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "active_scope": {
      "type": "string",
      "minLength": 1
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scope_id",
          "display_name",
          "summary"
        ],
        "properties": {
          "scope_id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "enter_payload": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
