{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appfs.dev/schemas/contact.profile.output.schema.json",
  "title": "AIIM Contact Profile Output",
  "type": "object",
  "required": [
    "id",
    "display_name"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "contact_id": {
      "type": "string",
      "minLength": 1
    },
    "name_en": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "send_message_action": {
      "type": "string",
      "minLength": 1
    },
    "last_active_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
