{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appfs.dev/schemas/app.actions.output.schema.json",
  "title": "AIIM App Actions Output",
  "type": "object",
  "required": [
    "app_id",
    "recommended_actions"
  ],
  "properties": {
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "summary"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "use_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "example_payload": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "contact_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "contact_id",
          "profile_path",
          "send_message_path"
        ],
        "properties": {
          "contact_id": {
            "type": "string",
            "minLength": 1
          },
          "profile_path": {
            "type": "string",
            "minLength": 1
          },
          "send_message_path": {
            "type": "string",
            "minLength": 1
          },
          "mention_tokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
