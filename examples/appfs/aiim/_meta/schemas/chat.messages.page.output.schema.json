{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appfs.dev/schemas/chat.messages.page.output.schema.json",
  "title": "Chat Messages Page",
  "type": "object",
  "required": [
    "items",
    "page"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "ts": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    },
    "page": {
      "type": "object",
      "required": [
        "handle_id",
        "page_no",
        "has_more",
        "mode"
      ],
      "properties": {
        "handle_id": {
          "type": "string",
          "minLength": 1
        },
        "page_no": {
          "type": "integer",
          "minimum": 0
        },
        "has_more": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "snapshot",
            "live"
          ]
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "retry_after_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
